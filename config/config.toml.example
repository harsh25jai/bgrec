# bgrec — sample configuration
# Copy to: %LOCALAPPDATA%\bgrec\config.toml
# Or run `bgrec config` after first launch (auto-created).

[recording]
# Microphone: omit `device` for system default, or set index/name from `bgrec list-devices`
# device = "0"
chunk_duration_seconds = 300
sample_rate = 16000
channels = 1
output_format = "mp3"    # flac | mp3
mp3_bitrate = "64k"
silence_detection = false
silence_threshold_db = -40.0
silence_min_duration_seconds = 30.0
# Keep system awake while recording (display may still turn off). Required for recording with lid closed.
prevent_sleep_during_recording = true

[upload]
enabled = true
retry_max_attempts = 5
retry_delay_seconds = 30
upload_workers = 2

# When enabled: keep .enc under recordings/encrypted locally; upload plain .mp3/.flac to Drive
[encryption]
enabled = false

[retention]
local_retention_days = 7
delete_after_upload = true

[startup]
enabled = false
use_registry = true

[logging]
level = "INFO"
max_bytes = 5242880
backup_count = 5

[google]
credentials_file = "credentials.json"
token_file = "token.json"
app_folder_name = "bgrec"

# Optional path overrides (defaults under %LOCALAPPDATA%\bgrec)
[paths]
# recordings = "D:\\AudioBackup\\recordings"
# cache = "D:\\AudioBackup\\cache"
# logs = "D:\\AudioBackup\\logs"
